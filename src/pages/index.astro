---
import Layout from '../layouts/Layout.astro';
---

<Layout title="خانه">
    
    <!-- Hero Section -->
    <section class="min-h-[50vh] flex flex-col justify-center items-center max-w-4xl mx-auto">
        
        <div class="flex flex-col items-center gap-6">
            
            <!-- Your Picture (بالا) -->
            <div class="relative shrink-0">
                <div class="w-40 h-40 md:w-60 md:h-60 rounded-full overflow-hidden border-2 border-slate-800 shadow-2xl shadow-indigo-500/20">
                    <img 
                        src="/profile.jpg" 
                        alt="سعید فرزپور" 
                        class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                    />
                </div>
            </div>

            <!-- Text (پایین عکس) -->
            <div class="text-center">
                <h2 class="font-['iransansbold'] text-4xl text-slate-200">
                    سعید فرض‌پور
                </h1>
                <p class="text-xl text-slate-400">
                    
				
                </p>
            </div>
        </div>
    </section>		

    <!-- Quote Section -->
    <section id="quote" class="py-2 max-w-3xl mx-auto text-center">
        <!-- Icon rotated 180 for RTL -->
        
        
        <!-- Using font-iran class -->
        <h2 class="font-['iransans'] text-2xl text-slate-200">
            "راستش را بخواهی من هرگز به تقدیر باور نداشتم اما این بار باید نگاهم به زندگی را تغییر می‌دادم. 
باید باور می‌کردم در این جهان ایستگاه‌های متروکه‌ای وجود دارند که زندگی ما را برای همیشه تغییر خواهند داد. اینکه کجا پیاده می‌شدم یا کجا سوار می‌شدم. اینکه سفر مرا به آدمی متفاوت بدل کرده بود. آنچه که روزی می‌پنداشتم رویدادی اتفاقی است به راستی تقدیر بود..."
        </h2>
        <p class="mt-4 text-indigo-400 font-medium"> </p>
    </section>

	    <!-- Book Introduction Section -->
    <section class="py-3 max-w-4xl mx-auto text-center border-t border-slate-900">
        <h2 class="text-slate-500 text-sm mb-8 uppercase tracking-widest">کتاب‌ها </h2>

        <!-- Book Image -->
        <div class="mb-10">
            <img 
                src="/book-cover.png" 
                alt="جلد کتاب" 
                class="w-48 md:w-56 shadow-2xl rounded-lg mx-auto hover:scale-105 transition-transform duration-300 object-cover"
            />
        </div>
        <h2 class="text-slate-500 text-sm mb-8 uppercase tracking-widest">رویا فروش جلد اول  </h2>  
        <!-- Links Container (Stacked and Centered) -->
        <div class="flex flex-col gap-4 items-center max-w-xs mx-auto">
            
            <!-- Publisher Link -->
            <a href="https://rowzanehnashr.com/product/%D8%B1%D9%88%DB%8C%D8%A7%D9%81%D8%B1%D9%88%D8%B4/" target="_blank" class="px-8 py-3 bg-indigo-600 text-white rounded-full hover:bg-indigo-700 transition-colors font-medium w-full text-center shadow-lg shadow-indigo-500/20">
                خرید نسخه چاپی
            </a>

            <!-- Fidibo Link -->
            <a href="https://fidibo.com/book/155015-%D8%B1%D9%88%DB%8C%D8%A7-%D9%81%D8%B1%D9%88%D8%B4-%D9%88%DB%8C%D8%B1%D8%A7%D8%B3%D8%AA-%D8%AC%D8%AF%DB%8C%D8%AF" target="_blank" class="px-8 py-3 border border-slate-700 text-slate-300 rounded-full hover:bg-slate-800 transition-colors font-medium w-full text-center">
                دانلود نسخه الکترونیک (فیدیبو)
            </a>

        </div>
    </section>
	
    <!-- Social Media Section -->
    <section class="py-16 max-w-4xl mx-auto text-center border-t border-slate-900">
       
        <div class="flex flex-wrap gap-6 justify-center">
            
            <!-- Youtube -->
            <a href="https://youtube.com/saeedfarzpour" target="_blank" class="group relative w-12 h-12 rounded-full border border-slate-700 flex items-center justify-center hover:border-indigo-500 hover:scale-110 transition-all duration-300 bg-slate-900/50">
                <img src="/youtube.png" alt="Youtube" class="w-6 h-6 object-contain" />
            </a>

            <!-- Instagram -->
            <a href="https://www.instagram.com/saeedfarzpour" target="_blank" class="group relative w-12 h-12 rounded-full border border-slate-700 flex items-center justify-center hover:border-pink-500 hover:scale-110 transition-all duration-300 bg-slate-900/50">
                <img src="/instagram.png" alt="Instagram" class="w-6 h-6 object-contain" />
            </a>

            <!-- telegram -->
            <a href="https://t.me/saeedfarzpour" target="_blank" class="group relative w-12 h-12 rounded-full border border-slate-700 flex items-center justify-center hover:border-sky-500 hover:scale-110 transition-all duration-300 bg-slate-900/50">
                <img src="/telegram.png" alt="X.com" class="w-6 h-6 object-contain" />
            </a>

            <!-- Galimalva -->
            <a href="https://galimalva.com" class="group relative w-12 h-12 rounded-full border border-slate-700 flex items-center justify-center hover:border-pink-400 hover:scale-110 transition-all duration-300 bg-slate-900/50">
                <img src="/galimalva.png" alt="Gmail" class="w-15 h-15 object-contain" />
            </a>

        </div>
    </section>

</Layout>