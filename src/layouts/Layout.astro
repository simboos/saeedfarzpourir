---
// src/layouts/Layout.astro
import '../styles/global.css'; // <--- ADD THIS LINE HERE

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="Saeed Farzpour Portfolio" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        
        <!-- Modern Google Font -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;1,400&family=Outfit:wght@300;500;700&display=swap" rel="stylesheet">
        
        <title>{title} - Saeed Farzpour</title>
    </head>
    <body class="bg-slate-950 text-white font-sans antialiased selection:bg-indigo-500 selection:text-white">

        <main class="pt-12 px-6">
            <slot />
        </main>
		    <!-- Footer / Copyright -->
    <footer class="py-8 border-t border-slate-900 text-center">
        <div class="max-w-4xl mx-auto px-6 text-slate-600 text-sm">
            <p>&copy; {new Date().getFullYear()} Saeed Farzpour. All rights reserved.</p>
        </div>
    </footer>
    </body>
</html>