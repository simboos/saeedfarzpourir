---
// src/components/ProjectCard.astro
interface Props {
    title: string;
    description: string;
    tags: string[];
    link: string;
}
const { title, description, tags, link } = Astro.props;
---

<li class="group relative border border-slate-800 rounded-2xl p-8 hover:border-indigo-500/50 transition-colors duration-300 bg-slate-900/50">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div>
            <h3 class="text-2xl font-bold mb-2 group-hover:text-indigo-400 transition-colors">{title}</h3>
            <p class="text-slate-400 mb-4 max-w-lg leading-relaxed">{description}</p>
            <div class="flex gap-2 flex-wrap">
                {tags.map(tag => (
                    <span class="text-xs font-mono text-slate-500 bg-slate-950 px-2 py-1 rounded border border-slate-800">
                        {tag}
                    </span>
                ))}
            </div>
        </div>
        <a href={link} class="shrink-0 px-5 py-2 border border-slate-700 rounded-lg text-sm hover:bg-slate-800 transition-colors text-center md:text-left">
            View Project &rarr;
        </a>
    </div>
</li>